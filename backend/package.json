{
  "name": "backend",
  "version": "1.0.0",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "dev:local": "dotenv -e .env.local -- node server.js",
    "dev:supabase": "dotenv -e .env.supabase -- node server.js",
    "build": "npm install && npx prisma generate",
    "prisma:studio": "prisma studio",
